{
  "name": "studylink",
  "version": "1.0.0",
  "description": "Academic social-learning platform",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=client & npm run dev --workspace=server",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "start": "npm start --workspace=server",
    "db:push": "npm run db:push --workspace=server",
    "db:migrate": "npm run db:migrate --workspace=server"
  },
  "keywords": [
    "education",
    "learning",
    "social",
    "forums",
    "study-groups",
    "ai-tutor"
  ],
  "author": "edmondira24@gmail.com",
  "license": "MIT"
}
